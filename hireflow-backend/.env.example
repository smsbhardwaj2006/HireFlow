# Copy this file to .env and fill in your real values.
# Never commit the real .env file to git — it's already in .gitignore.

DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset (or "development") for local SQLite — zero config needed.
# Set to "production" to switch to MySQL, matching the PRD's dev/prod split.
DJANGO_ENV=development

# ── Only needed when DJANGO_ENV=production ──
# Local MySQL:
DB_NAME=hireflow
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306
# OR a hosted database URL (e.g. Railway sets this automatically):
# DATABASE_URL=mysql://user:password@host:port/dbname

# Origins allowed to call this API from a browser (your frontend's URL)
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173
